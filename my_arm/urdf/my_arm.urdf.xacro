<?xml version="1.0"?>
<robot name="my_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">

     <material name="red">
        <color rgba="1 0 0 1"/>
    </material>

    <material name="white">
        <color rgba="1 1 1 1"/>
    </material>

    <material name="blue">
        <color rgba="0 0 1 1"/>
    </material>

    <material name="black">
      <color rgba="0 0 0 1"/>
    </material>

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
              <mesh filename="package://my_arm/mesh/based_link.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="black"/>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
              <mesh filename="package://my_arm/mesh/based_link.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="5.0"/>
            <origin xyz="0 0 0"/>
            <inertia
                ixx="0.013" ixy="0.0" ixz="0.0"
                iyy="0.015" iyz="0.0"
                izz="0.024"/>
        </inertial>
    </link>

    <link name="yaw_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 1.57"/>
            <geometry>
              <mesh filename="package://my_arm/mesh/shoulder.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="black"/>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="0 0 1.57"/>
            <geometry>
              <mesh filename="package://my_arm/mesh/shoulder.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="5.0"/>
            <origin xyz="0 0 0"/>
            <inertia
                ixx="0.013" ixy="0.0" ixz="0.0"
                iyy="0.015" iyz="0.0"
                izz="0.024"/>
        </inertial>
    </link>

    <link name="shoulder_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 1.57"/>
            <geometry>        
              <mesh filename="package://my_arm/mesh/harmonic_gearV2.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 1.57"/>
            <geometry>

                 <mesh filename="package://my_arm/mesh/harmonic_gearV2.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.2"/>
            <origin xyz="0 0 0"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>

      <link name="elbow_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 -1.57"/>
            <geometry>
                <mesh filename="package://my_arm/mesh/harmonic_gearV2.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 -1.57"/>
            <geometry>

                <mesh filename="package://my_arm/mesh/harmonic_gearV2.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.2"/>
            <origin xyz="0 0 0"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>

    <link name="wrist_pitch_link">
        <visual>
            <origin xyz="0 0 0" rpy="3.14 0 0"/>
            <geometry>
               
                <mesh filename="package://my_arm/mesh/micro_harmonic.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="3.14 0 0"/>
            <geometry>

                <mesh filename="package://my_arm/mesh/micro_harmonic.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.2"/>
            <origin xyz="0 0 0"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>

    <link name="wrist_roll_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 1.57 0"/>
            <geometry>
                <mesh filename="package://my_arm/mesh/micro_harmonic.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 1.57 0"/>
            <geometry>
                <mesh filename="package://my_arm/mesh/micro_harmonic.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.2"/>
            <origin xyz="0 0 0"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>

    <link name="shoulder_bar_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://my_arm/mesh/lower_arm_plate_with_motor.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://my_arm/mesh/lower_arm_plate_with_motor.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.2"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>

    <link name="elbow_bar_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://my_arm/mesh/upper_plate_with_motor.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://my_arm/mesh/upper_plate_with_motor.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.2"/>
            <origin xyz="0.1 0.005 0.1" rpy="0 0 0"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link> 
  <!-- <link name="elbow_bar_link">
        <visual>
            <origin xyz="0.1 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.2 0.005 0.01"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="0.1 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.2 0.005 0.1"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.2"/>
            <origin xyz="0.1 0.005 0.01" rpy="0 0 0"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link> -->

  <link name="wrist_pitch_bar_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://my_arm/mesh/pitch_frame.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://my_arm/mesh/pitch_frame.stl" scale="0.001 0.001 0.001"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.2"/>
            <origin xyz="0.1 0.005 0.01" rpy="0 0 0"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>

  <joint name="base_joint" type="revolute">
        <parent link="base_link"/>
        <child link="yaw_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="0" upper="3.14" effort="10" velocity="1"/>
  </joint>

  <joint name="shoulder_joint" type="revolute">
        <parent link="yaw_link"/>
        <child link="shoulder_link"/>
        <origin xyz="0 0.005 0.07" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="0" upper="3.14" effort="10" velocity="1"/>
  </joint>

  <joint name="shoulder_bar_joint" type="fixed">
        <parent link="shoulder_link"/>
        <child link="shoulder_bar_link"/>
        <origin xyz="0 -0.009 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

  <joint name="elbow_joint" type="revolute">
        <parent link="shoulder_bar_link"/>
        <child link="elbow_link"/>
        <origin xyz="-0.182 0.018 0.071" rpy="0 0.261799 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-3.14" upper="0" effort="10" velocity="1"/>
  </joint>
  
  <joint name="elbow_bar_joint" type="fixed">
        <parent link="elbow_link"/>
        <child link="elbow_bar_link"/>
        <origin xyz="0 -0.025 0" rpy="0 -0.2799 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

  <joint name="wrist_pitch_joint" type="revolute">
        <parent link="elbow_bar_link"/>
        <child link="wrist_pitch_link"/>
        <origin xyz="0.185 -0.015 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

  <joint name="wrist_pitch_bar_joint" type="fixed">
        <parent link="wrist_pitch_link"/>
        <child link="wrist_pitch_bar_link"/>
        <origin xyz="0 0.04 0" rpy="0 0 1.57"/>
        <axis xyz="0 1 0"/>
        <limit lower="0" upper="3.14" effort="10" velocity="1"/>
  </joint>

  <joint name="wrist_roll_joint" type="revolute">
        <parent link="wrist_pitch_bar_link"/>
        <child link="wrist_roll_link"/>
        <origin xyz="-0.015 -0.07 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="0" upper="3.14" effort="10" velocity="1"/>
  </joint>

    
</robot>